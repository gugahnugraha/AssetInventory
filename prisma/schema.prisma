datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMINISTRATOR
  OPERATOR
  MANAGER
}

enum Kondisi {
  NORMAL
  RUSAK_RINGAN
  RUSAK_BERAT
  HILANG
  DALAM_PERBAIKAN
  DIPINJAM
}

model Opd {
  id            String         @id @default(uuid())
  nama          String
  kode          String         @unique // e.g. "DISKOMINFO"
  kodeNumeric   String?        // e.g. "21.02.01.01"
  users         User[]
  distributions Distribution[]
  assets        Asset[]
  reconPeriods  ReconciliationPeriod[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model User {
  id           String     @id @default(uuid())
  nama         String
  username     String     @unique
  passwordHash String
  role         Role       @default(OPERATOR)
  opdId        String
  opd          Opd        @relation(fields: [opdId], references: [id])
  isActive     Boolean    @default(true)
  lastLogin    DateTime?
  auditLogs    AuditLog[]
  assetHistories AssetHistory[]
  documents    Document[]
  createdPeriods ReconciliationPeriod[] @relation("PeriodCreator")
  assetReconciliations AssetReconciliation[] @relation("AssetReconChecker")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Distribution {
  id        String   @id @default(uuid())
  nama      String   // e.g. Sekretariat, Aptika, Persandian
  kode      Int      // e.g. 1, 2, 3
  opdId     String
  opd       Opd      @relation(fields: [opdId], references: [id])
  holders       Holder[]
  assets        Asset[]
  fromHistories AssetHistory[] @relation("FromDistributionHistory")
  toHistories   AssetHistory[] @relation("ToDistributionHistory")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([nama, opdId])
  @@unique([kode, opdId])
}

model Holder {
  id             String       @id @default(uuid())
  nama           String
  nip            String       @unique
  jabatan        String
  distributionId String
  distribution   Distribution @relation(fields: [distributionId], references: [id])
  assets         Asset[]
  fromHistories  AssetHistory[] @relation("FromHolderHistory")
  toHistories    AssetHistory[] @relation("ToHolderHistory")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Category {
  id        String              @id @default(uuid())
  nama      String
  kibId     String
  kib       Kib                 @relation(fields: [kibId], references: [id])
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  attributes CategoryAttribute[]
  assets     Asset[]

  @@unique([nama, kibId])
}

model Kib {
  id          String     @id @default(uuid())
  kode        String     @unique // e.g. "A", "B", "C", "D", "E", "F"
  nama        String
  deskripsi   String?
  isActive    Boolean    @default(true)
  categories  Category[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model CategoryAttribute {
  id          String           @id @default(uuid())
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nama        String
  required    Boolean          @default(false)
  fieldType   String           @default("TEXT") // "TEXT", "NUMBER"
  displayOrder Int             @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  assetAttributes AssetAttribute[]

  @@unique([categoryId, nama])
}

model AssetAttribute {
  id                  String            @id @default(uuid())
  assetId             String
  asset               Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  categoryAttributeId String
  categoryAttribute   CategoryAttribute @relation(fields: [categoryAttributeId], references: [id], onDelete: Cascade)
  value               String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([assetId, categoryAttributeId])
}

model Asset {
  id             String            @id @default(uuid())
  kode1          String            // e.g. "02"
  kode2          String            // e.g. "05"
  kode3          String            // e.g. "01"
  kode4          String            // e.g. "03"
  kode5          String            // e.g. "02"
  nomorRegister  Int               // e.g. 1, 1000
  kodeLengkap    String            @unique // XX.XX.XX.XX.XX.XXX
  categoryId     String
  category       Category          @relation(fields: [categoryId], references: [id])
  namaAset       String            // e.g. "Mobil Avanza"
  merkType       String
  harga          Float             @default(0.0)
  tahunPembelian Int
  distributionId String
  distribution   Distribution      @relation(fields: [distributionId], references: [id])
  holderId       String?
  holder         Holder?           @relation(fields: [holderId], references: [id])
  kondisi        Kondisi           @default(NORMAL)
  catatan        String?
  fotoUtama      String?           // URL in Cloudflare R2
  opdId          String
  opd            Opd               @relation(fields: [opdId], references: [id])
  attributes     AssetAttribute[]
  auditLogs      AuditLog[]
  history        AssetHistory[]
  reconciliations AssetReconciliation[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}


model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  assetId   String?
  asset     Asset?    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  action    String   // "CREATE", "UPDATE", "DELETE"
  oldValue  String?  // JSON stringified old value
  newValue  String?  // JSON stringified new value
  createdAt DateTime @default(now())
}

enum MutationType {
  HOLDER
  DISTRIBUTION
  CONDITION
  MULTIPLE
}

model AssetHistory {
  id                 String                 @id @default(uuid())
  assetId            String
  asset              Asset                  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  mutationType       MutationType
  fromHolderId       String?
  fromHolder         Holder?                @relation("FromHolderHistory", fields: [fromHolderId], references: [id])
  toHolderId         String?
  toHolder           Holder?                @relation("ToHolderHistory", fields: [toHolderId], references: [id])
  fromDistributionId String?
  fromDistribution   Distribution?          @relation("FromDistributionHistory", fields: [fromDistributionId], references: [id])
  toDistributionId   String?
  toDistribution     Distribution?          @relation("ToDistributionHistory", fields: [toDistributionId], references: [id])
  fromCondition      Kondisi?
  toCondition        Kondisi?
  beritaAcaraNumber  String
  beritaAcaraDate    DateTime
  description        String?
  createdBy          String
  creator            User                   @relation(fields: [createdBy], references: [id])
  createdAt          DateTime               @default(now())
}

enum EntityType {
  ASSET
  MUTATION
  MAINTENANCE
  DISPOSAL
  RECONCILIATION
}

enum DocumentType {
  PHOTO
  BERITA_ACARA
  EVIDENCE
  INVOICE
  WARRANTY
  MANUAL
  CHECKLIST
  REPORT
  OTHER
}

model Document {
  id               String       @id @default(uuid())
  entityType       EntityType
  entityId         String
  documentType     DocumentType
  bucket           String
  objectKey        String
  originalFileName String
  mimeType         String
  size             Int
  isPrimary        Boolean      @default(false)
  uploadedBy       String
  uploader         User         @relation(fields: [uploadedBy], references: [id])
  uploadedAt       DateTime     @default(now())
  archivedAt       DateTime?
}

// =============================================
// REKONSILIASI ASET
// =============================================

enum ReconciliationStatus {
  OPEN
  LOCKED
  CLOSED
}

enum AssetReconciliationStatus {
  BELUM_DIREKON
  SESUAI
  TIDAK_SESUAI
}

enum FindingType {
  DATA_PEMEGANG
  DATA_DISTRIBUSI
  KONDISI
  LABEL
  FOTO
  DOKUMEN
  ASET_TIDAK_DITEMUKAN
  ASET_RUSAK
  ASET_HILANG
  LAINNYA
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingRecommendation {
  MUTASI_ASET
  PERBAIKAN_DATA
  PENGHAPUSAN_ASET
  UPLOAD_DOKUMEN
  PENGADAAN_LABEL
  TIDAK_ADA
}

model ReconciliationPeriod {
  id             String                 @id @default(uuid())
  nama           String
  triwulan       Int                    // 1, 2, 3, or 4
  tahun          Int
  tanggalMulai   DateTime
  tanggalSelesai DateTime
  status         ReconciliationStatus   @default(OPEN)
  opdId          String
  opd            Opd                    @relation(fields: [opdId], references: [id])
  createdBy      String
  creator        User                   @relation("PeriodCreator", fields: [createdBy], references: [id])
  reconciliations AssetReconciliation[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model AssetReconciliation {
  id             String                    @id @default(uuid())
  periodId       String
  period         ReconciliationPeriod      @relation(fields: [periodId], references: [id], onDelete: Cascade)
  assetId        String
  asset          Asset                     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  status         AssetReconciliationStatus @default(BELUM_DIREKON)
  checkedBy      String?
  checker        User?                     @relation("AssetReconChecker", fields: [checkedBy], references: [id])
  checkedAt      DateTime?
  notes          String?
  checklists     AssetReconciliationChecklist[]
  findings       ReconciliationFinding[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@unique([periodId, assetId])
}

model AssetReconciliationChecklist {
  id                    String              @id @default(uuid())
  assetReconciliationId String
  reconciliation        AssetReconciliation @relation(fields: [assetReconciliationId], references: [id], onDelete: Cascade)
  checklistItem         String
  checked               Boolean             @default(false)
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model ReconciliationFinding {
  id                    String                @id @default(uuid())
  assetReconciliationId String
  reconciliation        AssetReconciliation   @relation(fields: [assetReconciliationId], references: [id], onDelete: Cascade)
  findingType           FindingType
  severity              FindingSeverity
  description           String
  recommendation        FindingRecommendation @default(TIDAK_ADA)
  resolved              Boolean               @default(false)
  resolvedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

